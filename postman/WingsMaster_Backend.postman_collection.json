{
  "info": {
    "_postman_id": "2f6a8c92-0f20-4e50-a972-wingsmaster-api",
    "name": "WingsMaster Backend",
    "description": "Flujo API backend: login, catalogo, carrito, pedido, inventario, pago, factura y reportes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUsuarios", "value": "http://127.0.0.1:3000" },
    { "key": "baseProductos", "value": "http://127.0.0.1:3001" },
    { "key": "basePedidos", "value": "http://127.0.0.1:3002" },
    { "key": "baseInventario", "value": "http://127.0.0.1:3003" },
    { "key": "basePagos", "value": "http://127.0.0.1:3004" },
    { "key": "baseReportes", "value": "http://127.0.0.1:3005" },
    { "key": "adminEmail", "value": "admin@krunchy.local" },
    { "key": "clienteEmail", "value": "cliente@krunchy.local" },
    { "key": "seedPassword", "value": "Wings12345" },
    { "key": "adminToken", "value": "" },
    { "key": "clienteToken", "value": "" },
    { "key": "clienteId", "value": "" },
    { "key": "productoId", "value": "" },
    { "key": "pedidoId", "value": "" },
    { "key": "pedidoTotal", "value": "0" },
    { "key": "facturaId", "value": "" }
  ],
  "item": [
    {
      "name": "01 Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{seedPassword}}\"\n}"
        },
        "url": "{{baseUsuarios}}/api/usuarios/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('admin login ok', () => pm.response.to.have.status(200));",
            "const data = pm.response.json();",
            "pm.collectionVariables.set('adminToken', data.token);"
          ]
        }
      }]
    },
    {
      "name": "02 Login cliente",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{clienteEmail}}\",\n  \"password\": \"{{seedPassword}}\"\n}"
        },
        "url": "{{baseUsuarios}}/api/usuarios/login"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('cliente login ok', () => pm.response.to.have.status(200));",
            "const data = pm.response.json();",
            "pm.collectionVariables.set('clienteToken', data.token);",
            "pm.collectionVariables.set('clienteId', data._id);"
          ]
        }
      }]
    },
    {
      "name": "03 Catalogo publico",
      "request": {
        "method": "GET",
        "url": "{{baseProductos}}/api/productos"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('catalogo ok', () => pm.response.to.have.status(200));",
            "const data = pm.response.json();",
            "if (data.length) pm.collectionVariables.set('productoId', data[0]._id);"
          ]
        }
      }]
    },
    {
      "name": "04 Cliente no crea producto",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Temp cliente\",\n  \"descripcion\": \"No deberia pasar\",\n  \"precio\": 1000,\n  \"categoria\": \"Bebidas\"\n}"
        },
        "url": "{{baseProductos}}/api/productos"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('bloqueado por rol', () => pm.response.to.have.status(403));"]
        }
      }]
    },
    {
      "name": "05 Agregar al carrito",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productoId\": \"{{productoId}}\",\n  \"cantidad\": 2\n}"
        },
        "url": "{{baseProductos}}/api/carrito/{{clienteId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('carrito ok', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "06 Ver carrito",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
        "url": "{{baseProductos}}/api/carrito/{{clienteId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('carrito visible', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "07 Crear pedido desde carrito",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"direccionEnvio\": \"Calle 123 #45-67\",\n  \"insumos\": [\n    { \"itemNombre\": \"Alitas\", \"cantidad\": 2 },\n    { \"itemNombre\": \"Empaques\", \"cantidad\": 1 }\n  ]\n}"
        },
        "url": "{{basePedidos}}/api/pedidos"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('pedido creado', () => pm.response.to.have.status(201));",
            "const data = pm.response.json();",
            "pm.collectionVariables.set('pedidoId', data._id);",
            "pm.collectionVariables.set('pedidoTotal', data.total);"
          ]
        }
      }]
    },
    {
      "name": "08 Inventario admin",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseInventario}}/api/inventario"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('inventario ok', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "09 Procesar pago",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pedidoId\": \"{{pedidoId}}\",\n  \"monto\": {{pedidoTotal}},\n  \"metodoPago\": \"Tarjeta\"\n}"
        },
        "url": "{{basePagos}}/api/pagos/procesar"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('pago ok', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "10 Generar factura",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{clienteToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pedidoId\": \"{{pedidoId}}\",\n  \"monto\": {{pedidoTotal}},\n  \"metodoPago\": \"Tarjeta\"\n}"
        },
        "url": "{{basePagos}}/api/pagos/factura"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('factura creada', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('facturaId', pm.response.json()._id);"
          ]
        }
      }]
    },
    {
      "name": "11 Cliente no ve reportes",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{clienteToken}}" }],
        "url": "{{baseReportes}}/api/reportes/ventas-totales"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('reporte bloqueado', () => pm.response.to.have.status(403));"]
        }
      }]
    },
    {
      "name": "12 Ventas totales admin",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseReportes}}/api/reportes/ventas-totales"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('ventas ok', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "13 Producto mas vendido admin",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseReportes}}/api/reportes/producto-mas-vendido"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('producto top ok', () => pm.response.to.have.status(200));"]
        }
      }]
    },
    {
      "name": "14 Metricas mensuales admin",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseReportes}}/api/reportes/metricas-mensuales"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": ["pm.test('metricas ok', () => pm.response.to.have.status(200));"]
        }
      }]
    }
  ]
}
